# =============================================================================
# Codespace-Op Environment Configuration
# =============================================================================
# Copy this to .env.local and fill in real values for local development.
# NEVER commit real secrets to version control.

# --- Backend ---
BACKEND_PORT=7860
BACKEND_HOST=0.0.0.0
LOG_LEVEL=info

# --- MongoDB ---
MONGODB_URL=mongodb://admin:changeme@mongodb:27017
MONGODB_DB_NAME=codespace_op
MONGODB_USER=admin
MONGODB_PASSWORD=changeme

# --- Redis ---
REDIS_URL=redis://:changeme@redis:6379/0
REDIS_PASSWORD=changeme

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workspaces
MINIO_USE_SSL=false

# --- Firebase Auth ---
FIREBASE_CREDENTIALS_BASE64=
FIREBASE_PROJECT_ID=your-project-id

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_API_URL=http://localhost:7860

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o-mini

# --- Docker Workspace ---
DOCKER_NETWORK=codespace-op-internal
WORKSPACE_IMAGE_BASE=codespace-op/workspace-base:latest
WORKSPACE_MEMORY_LIMIT=512m
WORKSPACE_CPU_LIMIT=1.0
WORKSPACE_TIMEOUT_MINUTES=120

# --- Monitoring ---
GRAFANA_PASSWORD=admin

# --- Secrets (production only) ---
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# --- HuggingFace ---
HF_SPACE_NAME=your-username/codespace-op
HF_TOKEN=
