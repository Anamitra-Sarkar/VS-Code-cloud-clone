FROM codespace-op/workspace-base:latest

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-venv \
    python3-dev \
  && rm -rf /var/lib/apt/lists/*

USER coder

RUN pip3 install --no-cache-dir --user \
    pyright \
    python-lsp-server \
    black \
    ruff \
    pytest \
    ipython

ENV PATH="/home/coder/.local/bin:${PATH}"

ENTRYPOINT ["dumb-init", "code-server", "--bind-addr", "0.0.0.0:8080", "--auth", "none", "/home/coder/workspace"]
